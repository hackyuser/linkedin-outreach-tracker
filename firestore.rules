rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /leads/{leadId} {
      // Read: only the owner can fetch a lead document
      allow read: if request.auth != null
        && resource.data.userId == request.auth.uid;

      // Create: userId on the new document must match the signed-in user
      allow create: if request.auth != null
        && request.resource.data.userId == request.auth.uid;

      // Update: must own the document and cannot reassign userId
      allow update: if request.auth != null
        && resource.data.userId == request.auth.uid
        && request.resource.data.userId == request.auth.uid;

      // Delete: only the owner can remove a lead
      allow delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }
  }
}
