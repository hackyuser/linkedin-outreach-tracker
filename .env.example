# Firebase Web App Configuration
# Copy this file to .env.local and fill in values from the Firebase Console.
#
# Where to find these values:
# 1. Go to https://console.firebase.google.com/
# 2. Select your project (or create one)
# 3. Click the gear icon → Project settings
# 4. Under "Your apps", select your Web app (or click "Add app" → Web)
# 5. Copy the firebaseConfig object values into the variables below

# API Key — public client key for Firebase services
NEXT_PUBLIC_FIREBASE_API_KEY=

# Auth Domain — usually: YOUR_PROJECT_ID.firebaseapp.com
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=

# Project ID — your Firebase project identifier
NEXT_PUBLIC_FIREBASE_PROJECT_ID=

# Storage Bucket — usually: YOUR_PROJECT_ID.appspot.com or .firebasestorage.app
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=

# Messaging Sender ID — numeric sender ID for Firebase Cloud Messaging
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=

# App ID — unique identifier for your Firebase web app
NEXT_PUBLIC_FIREBASE_APP_ID=
